# Hospital CRM - Production Environment Configuration
# Copy this file to .env.production and fill in actual values

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=5000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/hospital_crm?retryWrites=true&w=majority

# ==========================================
# REDIS CACHE CONFIGURATION
# ==========================================
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
# Optional: REDIS_DB=0

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-secure-secret-key-min-32-characters-recommended-64
JWT_REFRESH_SECRET=your-very-long-secure-refresh-secret-key-min-32-characters-recommended-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# EMAIL CONFIGURATION (Nodemailer)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
# Gmail: Create App Password at https://myaccount.google.com/apppasswords
EMAIL_PASS=your-app-password-not-account-password

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Production frontend URL for CORS
CLIENT_URL=https://yourdomain.com

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================
# API RATE LIMITING
# ==========================================
# Enable rate limiting in production
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=200

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# CORS origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session secrets
SESSION_SECRET=your-session-secret-key-min-32-characters

# ==========================================
# OPTIONAL: MONITORING & ANALYTICS
# ==========================================
# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ==========================================
# OPTIONAL: PAYMENT GATEWAY
# ==========================================
# STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx

# ==========================================
# OPTIONAL: SMS NOTIFICATIONS
# ==========================================
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# DOCKER & DEPLOYMENT
# ==========================================
# Docker Compose services
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_BACKEND=yourusername/hospital-crm-backend
DOCKER_IMAGE_FRONTEND=yourusername/hospital-crm-frontend
IMAGE_TAG=latest

# ==========================================
# PRODUCTION FLAGS
# ==========================================
DEBUG=false
PRODUCTION=true
